clear();clf() 

printf("\n *** MÉTODO GRÁFICO PARA ISOLAR AS RAÍZES DA FUNÇÃO ***\n")

// define a variável simbólica e a função
s = poly(0, "x"); 
p = s^3 - 9*s + 3; 

// cria dados para o gráfico baseado no polinômio p
x_vetor = -4:0.1:4;
y_vetor = horner(p, x_vetor); // calcula os valores numéricos de p para cada x

plot2d(x_vetor, y_vetor)
h = gce() 
line_handle = h.children 
line_handle.thickness = 2 
line_handle.foreground = color('blue') 

xtitle("Localização das raízes: gráfico de f(x)");

a = gca() 
a.title.font_size = 4 
a.x_location = "origin";
a.y_location = "origin";

// acha as raízes do polinômio p
r = roots(p); 

// filtrar apenas raízes reais
raizes_reais = r(imag(r) == 0);
y_raizes = zeros(raizes_reais); 

// plota as raízes
plot(raizes_reais, y_raizes, 'r*'); 

// ajusta o tamanho dos pontos das raízes
h_pontos = gce(); 
h_pontos.children.mark_size = 10; 
h_pontos.children.mark_foreground = color('red');

xgrid()
